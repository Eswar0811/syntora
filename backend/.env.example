# ── Spotify OAuth ─────────────────────────────────────────────────────────────
# Create an app at https://developer.spotify.com/dashboard
# Add your redirect URI below as a Redirect URI in the Spotify Dashboard.
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Local dev:
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/callback
# Production (replace with your deployed backend URL):
# SPOTIFY_REDIRECT_URI=https://your-backend.railway.app/callback

# ── CORS / Frontend ───────────────────────────────────────────────────────────
# Local dev — Next.js frontend runs on 3000, legacy Vite on 5175
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5175

# Production (set to your Vercel deployment URL):
# FRONTEND_URL=https://your-syntora.vercel.app
# ALLOWED_ORIGINS=https://your-syntora.vercel.app
